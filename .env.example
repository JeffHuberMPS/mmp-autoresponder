# Copy to .env for LOCAL testing. On the cloud host, set these in its dashboard
# (never commit your real .env — it's gitignored).
ANTHROPIC_API_KEY=
IG_ACCESS_TOKEN=
IG_APP_SECRET=
IG_VERIFY_TOKEN=jarvis-secret-handshake
IG_GRAPH_BASE=https://graph.instagram.com/v21.0
PORT=8787

# ── Auto-Poster (free photo + schedule storage) ──
# Cloudinary → free image hosting (Dashboard → Account Details)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Upstash Redis → free permanent schedule storage (database → REST API section)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
